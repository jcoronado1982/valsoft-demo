# ==========================================
# Invoice Monorepo - Master GitIgnore
# ==========================================

# ------------------------------------------
# 🏢 System & IDEs
# ------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.bak
*.tmp
*.log
*.txt
.vscode/!tasks.json

.vscode/!launch.json
.vscode/!extensions.json
.idea/
*.user
*.userosscache
*.sln.docstates

# ------------------------------------------
# 🐘 Infrastructure & Docker
# ------------------------------------------
infra/volumes/
.env
.env.local
.env.*.local
! .env.example

# ------------------------------------------
# 🛠️ Backend (.NET 9)
# ------------------------------------------
**/[Bb]in/
**/[Oo]bj/
**/[Tt]est[Rr]esults/
appsettings.Development.json
secrets.json
.aspnet/
*.db
*.db-journal

# ------------------------------------------
# 🌐 Frontend (Angular / Bun)
# ------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/.vercel/
frontend/test-results/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun.lockb
! frontend/package.json
! frontend/bun.lockb

# ------------------------------------------
# 🐍 AI Worker (Python / UV)
# ------------------------------------------
**/venv/
**/.venv/
**/__pycache__/
**/.python-version
**/.agent/
**/generated/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
.cache
.mypy_cache/
.ipynb_checkpoints/
uv.lock
! ai/uv.lock

# ------------------------------------------
# 🤖 Agentic Coding & Brain (AI Assistants)
