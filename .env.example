# Configuración del Backend (C# .NET 9)
# Copia este archivo a un entorno de variables o usa una herramienta de gestión de secretos.

# Base de Datos PostgreSQL
DB_PASSWORD="your_password_here"
ConnectionStrings__inventorydb="Host=localhost;Port=5432;Database=inventory_db;Username=user;Password=${DB_PASSWORD}"

# Seguridad JWT
Jwt__Key="CAMBIAR_POR_UNA_CLAVE_DE_AL_MENOS_32_CARACTERES_ALEATORIOS"
Jwt__Issuer="backend-csharp"
Jwt__Audience="frontend-angular"

# Integración con Google
Google__ClientId="your-google-client-id-here"

# Super Admin RBAC Registration
Auth__SuperAdmin="your-email@example.com"

# Entorno de Ejecución
ASPNETCORE_ENVIRONMENT="Development"

